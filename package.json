{
  "name": "xiview",
  "version": "2.0.0a6",
  "description": "visualisation of crosslinking  mass spectrometry data",
  "keywords": [
    "xiVIEW",
    "crosslinking",
    "mass spectrometry",
    "protein",
    "interactions"
  ],
  "bugs": {
    "url": "https://github.com/Rappsilber-Laboratory/build-xiview/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Rappsilber-Laboratory/xiVIEW_container.git"
  },
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "Colin Combe",
    "email": "colin.combe@ed.ac.uk"
  },
  "contributors": [
    {
      "name": "Martin Graham",
      "email": "M.Graham@napier.ac.uk"
    },
    {
      "name": "Colin Combe",
      "email": "colin.combe@ed.ac.uk"
    },
    {
      "name": "Lars Kolbowski",
      "email": "lars.kolbowski@tu-berlin.de"
    },
    {
      "name": "Lutz Fischer",
      "email": "lutz.fischer@tu-berlin.de"
    }
  ],
  "main": "./xiview/js/main.js",
  "scripts": {
    "build-dev": "rm -rf dist && webpack --mode development --config webpack.dev.js;",
    "build-prod": "rm -rf dist && webpack --mode production --config webpack.prod.js;",
    "build-dev-and-copy-to-xiview-server": "npm run build-dev; cp dist/* ../xiview-server/static/ ;",
    "build-prod-and-copy-to-xiview-server": "npm run build-prob; cp dist/xiview.js ../xiview-server/static/xiview.js;",
    "lint": "eslint CLMS-model/src crosslink-viewer/js xiview/js spectrum/src",
    "test": "npm run build-dev && npm run test-headless",
    "test-headless": "node scripts/run-tests.js"
  },
  "dependencies": {
    "@eastdesire/jscolor": "~2.5.2",
    "backbone": "~1.6.0",
    "colorbrewer": "~1.3.0",
    "core-js": "~3.36.0",
    "d3": "~3.5.17",
    "datatables.net": "~2.0.0",
    "datatables.net-dt": "~1.13.10",
    "jquery": "~3.7.1",
    "jquery-ui": "~1.14.1",
    "jsonview": "~1.2.0",
    "ngl": "~2.3.1",
    "path-browserify": "^1.0.1",
    "spin": "~0.0.1",
    "split.js": "~1.6.4",
    "sprintf-js": "~1.1.3",
    "underscore": "~1.13.1"
  },
  "devDependencies": {
    "@babel/core": "^7.21.5",
    "@babel/preset-env": "^7.21.5",
    "babel-loader": "^9.1.2",
    "css-loader": "^5.2.7",
    "eslint": "^8.39.0",
    "file-loader": "^6.2.0",
    "jsdom": "^22.1.0",
    "puppeteer": "^24.0.0",
    "qunit": "2.21.1",
    "style-loader": "^3.3.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.81.0",
    "webpack-cli": "^5.0.2",
    "webpack-merge": "^5.8.0"
  },
  "engines": {
    "node": ">=20.12.1 "
  }
}
